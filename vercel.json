{
  "version": 2,
  "builds": [
    {
      "src": "api/test.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "workspace/meetspot_finder.html",
      "use": "@vercel/static"
    },
    {
      "src": "docs/logo.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/workspace/meetspot_finder.html"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/workspace/meetspot_finder.html",
      "dest": "/workspace/meetspot_finder.html"
    },
    {
      "src": "/docs/logo.png",
      "dest": "/docs/logo.png"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/test.py"
    },
    {
      "src": "/health",
      "dest": "/api/test.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/test.py"
    }
  ],
  "env": {
    "DEBUG": "true"
  }
}
